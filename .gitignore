# Python, test, and tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest_tmp*/
.ruff_cache/
.mypy_cache/
.pytype/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Environments and packaging
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# Notebook, editor, and OS files
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Native/CUDA outputs
*.o
*.obj
*.so
*.pyd
*.dll
*.dylib
*.lib
*.exp
*.ninja

# Runtime caches and experiment outputs
.minitrain-storage.env*
.triton_cache/
triton_cache/
/runs/
logs/
checkpoints/
wandb/
outputs/
profiles/
/artifacts

# Large model/data artifacts
*.pt
*.pth
*.safetensors
*.ckpt
*.bin
*.npy
*.npz

# Portable server evidence is versioned: benchmark JSON/CSV/plots, validation
# reports, logs, environment inventories, run events, and checkpoint metadata.
# Tensor payloads and raw dataset shards remain on the mounted artifacts disk.
!/results/
!/results/**
/results/**/distributed/
/results/**/*.distcp
/results/**/*.pt
/results/**/*.pth
/results/**/*.safetensors
/results/**/*.ckpt
/results/**/*.bin
/results/**/*.npy
/results/**/*.npz
!/results/**/runtime.pt
!/results/**/rng_rank_*.pt

# Tests, benchmark results, and reports are shareable.
!tests/**
!reports/**
# Machine-specific benchmark notebooks are local execution artifacts. Keep the
# portable notebook variants tracked and regenerate these per target machine.
# tests/**/*_sm86_4gb.ipynb
# tests/**/*_linux_server.ipynb
tests/**/__pycache__/
tests/**/*.py[cod]
reports/**/__pycache__/
reports/**/*.py[cod]

# temp for ignored: docs
# .docs/
