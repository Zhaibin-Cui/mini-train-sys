# Python, test, and tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest_tmp*/
.ruff_cache/
.mypy_cache/
.pytype/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Environments and packaging
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# Notebook, editor, and OS files
.ipynb_checkpoints/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Native/CUDA outputs
*.o
*.obj
*.so
*.pyd
*.dll
*.dylib
*.lib
*.exp
*.ninja

# Runtime caches and experiment outputs
.triton_cache/
triton_cache/
runs/
logs/
checkpoints/
wandb/
outputs/
profiles/

# Large model/data artifacts
*.pt
*.pth
*.safetensors
*.ckpt
*.bin
*.npy
*.npz

# Tests and reports are shareable; their generated caches/results are not.
!tests/**
!reports/**
tests/**/__pycache__/
tests/**/*.py[cod]
tests/benchmark_results/
reports/**/__pycache__/
reports/**/*.py[cod]
